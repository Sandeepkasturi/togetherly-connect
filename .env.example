# ============================================================================
# PHASE 0: SECURITY & INFRASTRUCTURE
# ============================================================================

# Supabase Configuration (Required)
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ============================================================================
# PHASE 1: NAVIGATION & SPACE PRIMITIVE
# ============================================================================

# Google OAuth for One Tap Authentication
# Create at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=123456789-abc...your-client-id...apps.googleusercontent.com

# ============================================================================
# PHASE 2: STUDY ROOM FEATURES
# ============================================================================

# (No additional env vars for Phase 2)

# ============================================================================
# PHASE 3: INTERVIEW ROOM FEATURES
# ============================================================================

# Judge0 Code Execution API (Free tier: 50 requests/day)
# Sign up at: https://judge0.com
VITE_JUDGE0_API_KEY=your-judge0-api-key
VITE_JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# ============================================================================
# PHASE 4 & 5: MONETIZATION & AI
# ============================================================================

# Razorpay for Payments (India-focused)
# Get keys from: https://dashboard.razorpay.com/
VITE_RAZORPAY_KEY_ID=rzp_live_your_key_id

# Google Gemini AI API
# Get key from: https://ai.google.dev
VITE_GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# PEER-TO-PEER COMMUNICATION (SECURITY CRITICAL)
# ============================================================================

# WebRTC STUN/TURN Servers
# TURN credentials from: Twilio, AWS, or self-hosted TURN server
# Format: turn:turn.example.com:3478?transport=tcp

# TURN Server (Primary - Required for NAT traversal)
VITE_TURN_URL=turn:your-turn-server.com:3478
VITE_TURN_USERNAME=your-turn-username
VITE_TURN_PASSWORD=your-turn-password

# Push Notifications (Web Push API)
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ============================================================================
# DEPLOYMENT & MONITORING (Optional)
# ============================================================================

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=

# PostHog Analytics (Optional)
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_API_HOST=https://app.posthog.com
